# Supabase — get these from your project at https://app.supabase.com (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server-only, NEVER expose to the browser. Used by admin/server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used in emails / redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
